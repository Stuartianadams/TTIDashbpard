# ─────────────────────────────────────────────────────────────────────────────
# TTI Dashboard — Environment Variables
# Copy this file to .env.local for local development.
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL connection string (required)
#
# Local development:
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/tti_dashboard"
#
# Railway — paste the Internal connection string from:
#   Railway project → Postgres service → Variables tab → DATABASE_URL
# DATABASE_URL="postgresql://postgres:PASSWORD@HOST:PORT/railway"
#
# For Vercel deployments, append connection params to avoid pool exhaustion:
# DATABASE_URL="postgresql://postgres:PASSWORD@HOST:PORT/railway?connection_limit=5&pool_timeout=20"

# ─────────────────────────────────────────────────────────────────────────────
# DIRECT_URL — only needed if you add a connection pooler (PgBouncer,
# Supabase pgBouncer, Prisma Accelerate, etc.)
# If set, also add to prisma/schema.prisma:  directUrl = env("DIRECT_URL")
# ─────────────────────────────────────────────────────────────────────────────
# DIRECT_URL="postgresql://postgres:PASSWORD@HOST:PORT/railway"
